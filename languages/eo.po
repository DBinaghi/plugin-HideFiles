#: HideFilesPlugin.php:13
msgid "Hidden by Hide Files plugin"
msgstr "Kaŝita de la kromprogramo Hide Files"

#: HideFilesPlugin.php:68
msgid "%sWarning%s: this will remove all information added by this plugin, thus files will no more be hidden."
msgstr "%sAtentu%s: ĉi tio forigos ĉiujn informojn aldonitajn de ĉi tiu kromprogramo, tial dosieroj ne plu estos kaŝitaj."

#: controllers/IndexController.php:36
msgid "You do not have the rights to view this list."
msgstr "Vi ne rajtas vidi ĉi tiun liston."

#: HideFilesPlugin.php:141 browse.php:1
msgid "Hidden Files"
msgstr "Kaŝitaj Dosieroj"

#: HideFilesPlugin.php:152
msgid "You do not have the rights to edit this file."
msgstr "Vi ne rajtas redakti ĉi tiun dosieron."

#: HideFilesPlugin.php:191
msgid "File Status"
msgstr "Statuso de la dosiero"

#: HideFilesPlugin.php:158 HideFilesPlugin.php:192 HideFilesPlugin.php:204
msgid "Public"
msgstr "Publika"

#: HideFilesPlugin.php:193
msgid "Yes"
msgstr "Jes"

#: HideFilesPlugin.php:193
msgid "No"
msgstr "Ne"

#: HideFilesPlugin.php:202
msgid "Visibility"
msgstr "Videbleco"

#: HideFilesPlugin.php:277
msgid "The file is now Public, so any visitor and user can see it."
msgstr "La dosiero estas nun publika, do ĉiu vizitanto kaj uzanto povas vidi ĝin."

#: HideFilesPlugin.php:279
msgid "Access to the file has now been restricted via the Hide Files plugin."
msgstr "La aliro al la dosiero estas nun limigita per la kromprogramo Hide Files."

#: config_form.php:5
msgid "Scope"
msgstr "Amplekso"

#: config_form.php:9
msgid "Restrict Users Access"
msgstr "Limigi alironon de uzantoj"

#: config_form.php:13
msgid "If checked, plugin features will be applied also to most logged-in users (a hidden file will be viewable only by its owner and by Administrators)."
msgstr "Se markita, la funkcioj de la kromprogramo estos aplikataj ankaŭ al la plej multaj ensalutintaj uzantoj (kaŝita dosiero estos videbla nur de ĝia posedanto kaj de Administrantoj)."

#: config_form.php:17
msgid "Note: visitors who are not logged in will never be able to see non-public files, regardless of this setting."
msgstr "Noto: vizitantoj kiuj ne estas ensalutintaj neniam povos vidi ne-publikajn dosierojn, sendepende de ĉi tiu agordo."

#: config_form.php:21
msgid "Hide on Public Side"
msgstr "Kaŝi en publika flanko"

#: config_form.php:25
msgid "If checked, files will always be hidden on Public side, regardless of whether the user is logged-in or not."
msgstr "Se markita, dosieroj ĉiam estos kaŝitaj en la publika flanko, sendepende de tio ĉu la uzanto estas ensalutinta aŭ ne."

#: config_form.php:31
msgid "Admin"
msgstr "Administrado"

#: config_form.php:35
msgid "Show Hidden Files List"
msgstr "Montri liston de kaŝitaj dosieroj"

#: config_form.php:39
msgid "If checked, a link will be added to the main Admin navigation menu to show a list of all hidden files."
msgstr "Se markita, ligilo estos aldonita al la ĉefa navigada menuo de Administrado por montri liston de ĉiuj kaŝitaj dosieroj."

#: config_form.php:47
msgid "Expand Access to File List"
msgstr "Pligrandigi aliron al listo de dosieroj"

#: config_form.php:51
msgid "If checked, contributors (and all derived roles) will also be able to access the hidden files list."
msgstr "Se markita, ankaŭ kontribuantoj (kaj ĉiuj roloj derivitaj de tiu) povos aliri la liston de kaŝitaj dosieroj."

#: config_form.php:57
msgid "Show Original Filename"
msgstr "Montri originalan dosiernomon"

#: config_form.php:61
msgid "If checked, when browsing hidden files the original filename will be shown."
msgstr "Se markita, dum la konsultado de kaŝitaj dosieroj la originala dosiernomo estos montrata."

#: browse.php:7
msgid "This is the file stored in the repository and hidden via the <strong>Hide Files</strong> plugin."
msgid_plural "These are the %s files stored in the repository and hidden via the <strong>Hide Files</strong> plugin."
msgstr[0] "Ĉi tiu estas la dosiero konservita en la deponejo kaj kaŝita per la kromprogramo <strong>Hide Files</strong>."
msgstr[1] "Ĉi tiuj estas la %s dosieroj konservitaj en la deponejo kaj kaŝitaj per la kromprogramo <strong>Hide Files</strong>."

#: browse.php:9
msgid "Click on a filename to access that specific file, or on an Item name to access the associated Item."
msgstr "Klaku sur dosiernomon por aliri tiun dosieron, aŭ sur nomon de Ero por aliri la asociitan Eron."

#: browse.php:18
msgid "Filename"
msgstr "Dosiernomo"

#: browse.php:19
msgid "Date Added"
msgstr "Dato de aldono"

#: browse.php:20
msgid "Item"
msgstr "Ero"

#: browse.php:53
msgid "There seems to be no file stored in the repository and hidden via the <strong>Hide Files</strong> plugin."
msgstr "Ŝajnas ke neniu dosiero estas konservita en la deponejo kaj kaŝita per la kromprogramo <strong>Hide Files</strong>."